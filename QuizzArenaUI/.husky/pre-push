#!/bin/sh
# ── Husky bootstrap ───────────────────────────────────────────────────────────
_husky="$(dirname "$0")/_/husky.sh"
# shellcheck disable=SC1090
[ -f "$_husky" ] && . "$_husky"
[ "${HUSKY:-1}" = "0" ] && exit 0
[ "${CI:-}" = "true" ]  && exit 0
# ─────────────────────────────────────────────────────────────────────────────

# ── Pre-push gate (thorough checks) ──────────────────────────────────────────
# Runs heavier checks before code reaches the remote. Output streams in
# real-time so every diagnostic is visible as it happens.
#
# Checks:
#   1. ESLint                      (just lint)
#   2. Prettier formatting         (just format)
#   3. TypeScript type-check       (just type-check)
#   4. Unit tests                  (just test)
#   5. Full git history secret scan(just scan-secrets)
#   6. npm vulnerability audit     (just audit)
#
# The production build runs in CI (feature-ci / pr-security) rather than here,
# to keep the local gate responsive on slow mounts.
#
# Force-skip (strongly discouraged): git push --no-verify
# ─────────────────────────────────────────────────────────────────────────────

cd "$(git rev-parse --show-toplevel)" || exit 1

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

SEP="────────────────────────────────────────────────────"
DIVIDER="════════════════════════════════════════════════════"

if ! command -v just > /dev/null 2>&1; then
    printf "${YELLOW}⚠  'just' not found — pre-push checks skipped.${RESET}\n"
    printf "   Install: devbox add just  or  https://just.systems\n\n"
    exit 0
fi

FAILED_CHECKS=""
FAILED_COUNT=0
PASSED_COUNT=0

run_check() {
    label="$1"
    task="$2"

    printf "\n${CYAN}${BOLD}▶ ${label}${RESET}\n"
    printf "${SEP}\n"

    # Stream output directly — no capturing, diagnostics print as they happen.
    just "${task}"
    status=$?

    printf "${SEP}\n"
    if [ ${status} -eq 0 ]; then
        printf "${GREEN}✔  ${label} passed${RESET}\n"
        PASSED_COUNT=$((PASSED_COUNT + 1))
    else
        printf "${RED}✘  ${label} failed (exit ${status})${RESET}\n"
        FAILED_CHECKS="${FAILED_CHECKS}\n    • ${label}  →  just ${task}"
        FAILED_COUNT=$((FAILED_COUNT + 1))
    fi
}

printf "\n${BOLD}Pre-push checks${RESET}\n"
printf "${DIVIDER}\n"

run_check "ESLint"                   "lint"
run_check "Prettier formatting"      "format"
run_check "TypeScript type-check"    "type-check"
run_check "Unit tests"               "test"
run_check "Full git history secrets" "scan-secrets"
run_check "npm vulnerability audit"  "audit"

printf "\n${DIVIDER}\n"

TOTAL=$((PASSED_COUNT + FAILED_COUNT))

if [ ${FAILED_COUNT} -gt 0 ]; then
    printf "\n${RED}${BOLD}✘  ${FAILED_COUNT}/${TOTAL} checks failed — push blocked.${RESET}\n"
    printf "${FAILED_CHECKS}\n"
    printf "\n${BOLD}Fix the issues above and retry.${RESET}\n"
    printf "${YELLOW}To bypass (strongly discouraged): git push --no-verify${RESET}\n\n"
    exit 1
fi

printf "\n${GREEN}${BOLD}✔  ${PASSED_COUNT}/${TOTAL} checks passed — pushing.${RESET}\n\n"
exit 0
