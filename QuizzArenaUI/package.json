{
  "name": "quizz-arena-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:i18n": "ng build --localize && node -e \"const fs=require('fs');fs.copyFileSync('public/serve.json','dist/QuizzArenaUI/browser/serve.json');fs.copyFileSync('public/index.html','dist/QuizzArenaUI/browser/index.html');\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --check \"src/**/*.{ts,html,scss,css,json}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,html,scss,css,json}\"",
    "type-check": "tsc -p tsconfig.app.json --noEmit",
    "prepare": "cd .. && git config core.hooksPath QuizzArenaUI/.husky || true"
  },
  "private": true,
  "packageManager": "npm@11.2.0",
  "dependencies": {
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@auth0/angular-jwt": "^5.2.0",
    "angular-oauth2-oidc": "^20.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@angular/localize": "^22.0.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.12",
    "angular-eslint": "22.0.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.0.8"
  }
}
