# Copy to .env and adjust values before running `just up`

# Keycloak admin credentials (used to bootstrap the dev container)
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin

# Port Keycloak listens on (change if 8180 is already in use)
KEYCLOAK_PORT=8180

# OAuth client registered in the quiz-arena realm
KEYCLOAK_CLIENT_ID=quiz-arena-ui

# Backend API base URL (used to populate runtime config.json)
API_BASE_URL=http://localhost:8080
